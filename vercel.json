{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --prefix green-fingers",
  "buildCommand": "npm --prefix green-fingers run build",
  "outputDirectory": "green-fingers/dist/green-fingers/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
